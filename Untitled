.neural-container { position: absolute; width: 100%; height: 100%; top: 0px; left: 0px; display: grid; grid-template-columns: repeat(20, 1fr); grid-template-rows: repeat(20, 1fr); pointer-events: none; z-index: 5; }

.data-node { border: 0.5px solid rgba(0, 255, 65, 0.05); transition: 0.5s; position: relative; }

.data-node:hover { background: rgba(0, 255, 65, 0.1); border-color: var(--neon-green); pointer-events: auto; }

.chart-container { position: absolute; bottom: 40px; left: 20px; width: 400px; height: 150px; background: rgba(0, 10, 5, 0.8); border: 1px solid var(--neon-green); padding: 10px; z-index: 160; display: flex; align-items: flex-end; gap: 5px; }

.chart-bar { flex: 1 1 0%; background: linear-gradient(to top, var(--neon-green), transparent); animation: 2s ease-in-out 0s infinite alternate none running bar-grow; position: relative; }

.chart-bar::before { content: ""; position: absolute; top: -5px; left: 0px; width: 100%; height: 2px; background: rgb(255, 255, 255); box-shadow: rgb(255, 255, 255) 0px 0px 10px; }

@keyframes bar-grow { 
  0% { height: 20%; opacity: 0.5; }
  100% { height: 80%; opacity: 1; }
}

.data-ring { position: absolute; border-width: 2px; border-style: solid; border-right-color: transparent; border-left-color: transparent; border-image: initial; border-top-color: var(--neon-green); border-bottom-color: rgb(0, 212, 255); border-radius: 50%; animation: auto linear 0s infinite normal none running ring-spin; }

@keyframes ring-spin { 
  0% { transform: rotate(0deg) scale(1); }
  100% { transform: rotate(360deg) scale(1.1); }
}

.hud-bracket { position: absolute; width: 30px; height: 30px; border: 2px solid var(--neon-green); }

.tl { top: 50px; left: 50px; border-right: 0px; border-bottom: 0px; }

.tr { top: 50px; right: 50px; border-left: 0px; border-bottom: 0px; }

.bl { bottom: 50px; left: 50px; border-right: 0px; border-top: 0px; }

.br { bottom: 50px; right: 50px; border-left: 0px; border-top: 0px; }

.code-typing { font-size: 9px; color: var(--neon-green); white-space: pre; overflow: hidden; display: block; }

.logic-bridge { width: 100%; height: 1px; background: rgba(0, 255, 65, 0.2); margin: 5px 0px; }

.depth-layer-1 { transform: translateZ(-100px); opacity: 0.3; }

.depth-layer-2 { transform: translateZ(-200px); opacity: 0.1; }

.vertical-scroller { position: absolute; top: 0px; width: 20px; height: 100%; overflow: hidden; font-size: 8px; line-height: 1; opacity: 0.2; text-align: center; }
