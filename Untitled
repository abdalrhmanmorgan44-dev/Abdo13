@charset "utf-8";

.particle-container { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; pointer-events: none; z-index: 1; }

.particle { position: absolute; background: var(--neon-green); width: 1px; height: 1px; opacity: 0.3; will-change: transform; animation: auto linear 0s infinite normal none running fall; }

@keyframes fall { 
  0% { transform: translateY(-10vh) translateX(0px); }
  100% { transform: translateY(110vh) translateX(20px); }
}

.edge-frame { position: absolute; border: 1px solid rgba(0, 255, 65, 0.1); pointer-events: none; z-index: 200; }

.top-left-frame { top: 10px; left: 10px; width: 50px; height: 50px; border-right: none; border-bottom: none; }

.bottom-right-frame { bottom: 10px; right: 10px; width: 50px; height: 50px; border-left: none; border-top: none; }

.glitch-fast { position: relative; display: inline-block; }

.glitch-fast::after { content: attr(data-text); position: absolute; left: 2px; text-shadow: red -1px 0px; top: 0px; background: black; overflow: hidden; clip: rect(0px, 900px, 0px, 0px); animation: 2s linear 0s infinite alternate-reverse none running glitch-anim; }

@keyframes glitch-anim { 
  0% { clip: rect(10px, 9999px, 20px, 0px); }
  20% { clip: rect(30px, 9999px, 40px, 0px); }
  40% { clip: rect(50px, 9999px, 60px, 0px); }
  60% { clip: rect(70px, 9999px, 80px, 0px); }
  80% { clip: rect(90px, 9999px, 100px, 0px); }
  100% { clip: rect(110px, 9999px, 120px, 0px); }
}

.cmd-bar { position: absolute; bottom: 0px; left: 0px; width: 100%; background: rgba(0, 255, 65, 0.1); height: 25px; display: flex; align-items: center; padding: 0px 15px; font-size: 10px; border-top: 1px solid var(--neon-green); z-index: 300; backdrop-filter: blur(10px); }

.stream-box { position: absolute; left: 20px; top: 30%; height: 300px; width: 1px; background: linear-gradient(to bottom, transparent, var(--neon-green), transparent); animation: 3s linear 0s infinite normal none running stream-move; }

@keyframes stream-move { 
  0% { transform: scaleY(0); opacity: 0; }
  50% { transform: scaleY(1); opacity: 1; }
  100% { transform: scaleY(0); opacity: 0; }
}

.logic-spacer { display: none; }

.p-fast { animation-duration: 1s; }

.p-slow { animation-duration: 5s; }

.p-mid { animation-duration: 3s; }
